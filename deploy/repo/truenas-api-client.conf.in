# OPNsense pkg repository for the os-truenas-api-client plugin.
#
# Install on a node as /usr/local/etc/pkg/repos/truenas-api-client.conf and place
# the matching public key at /usr/local/etc/pkg/keys/truenas-api-client.pub. The
# release workflow renders this template (substituting @PAGES_URL@) and publishes
# the ready-to-use file at @PAGES_URL@/truenas-api-client.conf — fetch that rather
# than editing this by hand.
#
# ${ABI} expands client-side (e.g. FreeBSD:14:amd64), so one conf works across
# FreeBSD/OPNsense ABIs as long as the feed publishes that ABI's directory.
truenas-api-client: {
  url: "@PAGES_URL@/${ABI}",
  priority: 10,
  enabled: yes,
  signature_type: "pubkey",
  pubkey: "/usr/local/etc/pkg/keys/truenas-api-client.pub"
}
